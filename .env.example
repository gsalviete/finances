# finances — variáveis de ambiente
#
# Este arquivo documenta TODAS as variáveis obrigatórias do projeto.
# Copie para `.env` e ajuste se necessário: cp .env.example .env
# Nunca commitar `.env`. Valores abaixo são apenas para DESENVOLVIMENTO local.

# --- Docker / ambiente de desenvolvimento (Fase 4) ---

# MongoDB
MONGO_PORT=27017
MONGO_ROOT_USER=finances
MONGO_ROOT_PASSWORD=finances-dev-password
MONGO_DB=finances

# Mongo Express (UI de inspeção do banco — apenas dev)
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin-dev-password

# Apps (porta exposta no host; internamente api=3001 e web=3000)
API_PORT=3001
WEB_PORT=3000

# --- Fases futuras (adicionadas na fase que as introduzir) ---
#   - Fase 7  (API NestJS):   NODE_ENV, LOG_LEVEL
#   - Fase 8  (Persistência): MONGODB_URI
#   - Fase 9  (Auth):         JWT_SECRET, JWT_EXPIRES_IN
#   - Fase 18 (Backup):       BACKUP_PROVIDER e credenciais de object storage
